{
  "name": "foodshare-workspace",
  "version": "1.0.0",
  "description": "Root workspace to start frontend and backend together",
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix \"foodshare-react/foodbridgepage\"",
    "start:backend": "npm start --prefix backend",
    "start:frontend": "npm run dev --prefix \"foodshare-react/foodbridgepage\"",
    "dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
